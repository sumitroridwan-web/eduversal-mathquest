# ==========================================================
# Eduversal MathQuest — Environment Variables (example)
# Copy to .env.local and fill in real values for backend work.
# The prototype runs entirely on mock data + localStorage and
# does NOT require any of these to be set.
# ==========================================================

# --- App ---
NEXT_PUBLIC_APP_NAME="Eduversal MathQuest"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Feature flags ---
# Show the demo-account switcher / role switching UI. Set to "false" in production.
NEXT_PUBLIC_DEMO_MODE="true"

# --- Supabase (future backend) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Database (future) ---
DATABASE_URL="postgresql://user:password@localhost:5432/mathquest"

# --- Auth (future) ---
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# --- Email (future, for password reset / verification) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="no-reply@eduversal.org"
DATABASE_URL="file:./dev.db"
